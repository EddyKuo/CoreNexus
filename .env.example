# CoreNexus 環境變數範本
# 複製此檔案並重新命名為 .env，填入實際值後再啟動服務
# 警告：.env 絕對不可提交到 Git！

# ── JWT 簽名金鑰（必填）────────────────────────────────────
# 最少 32 bytes 的隨機字串
# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── 資料庫連線（必填）──────────────────────────────────────
# 格式：postgresql+asyncpg://帳號:密碼@主機:埠號/資料庫名
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/corenexus

# ── 開發選項（選填）────────────────────────────────────────
# 設為 "true" 時會在 log 中輸出所有 SQL 語句（僅限開發環境）
SQL_ECHO=false
